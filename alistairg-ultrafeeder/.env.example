# Copy this to `.env` in the app's data directory after install:
#   ~/umbrel/app-data/alistairg-ultrafeeder/.env
# Then restart the app from the Umbrel UI.

# ---- Receiver location (required) ----
SITE_LAT=0.000000
SITE_LON=0.000000
SITE_ALT_M=0

# ---- Timezone ----
TZ=America/Los_Angeles

# ---- Ultrafeeder receiver UUID ----
# Generate once with: uuidgen
ULTRAFEEDER_UUID=

# ---- Aggregator feed list ----
# Semicolon-separated. Append per-aggregator UUIDs as a 5th field if you have them
# (e.g. adsb,feed.adsb.fi,30004,beast_reduce_plus_out,<uuid>).
ULTRAFEEDER_CONFIG=adsb,feed.adsb.fi,30004,beast_reduce_plus_out;adsb,in.adsb.lol,30004,beast_reduce_plus_out;adsb,feed.adsb.one,64004,beast_reduce_plus_out;adsb,feed.planespotters.net,30004,beast_reduce_plus_out;adsb,feed.theairtraffic.com,30004,beast_reduce_plus_out;mlat,feed.adsb.fi,31090,39000;mlat,in.adsb.lol,31090,39001;mlat,feed.adsb.one,64006,39002;mlat,mlat.planespotters.net,31090,39003;mlat,feed.theairtraffic.com,31090,39004

# ---- FlightAware (piaware) ----
# Get a feeder ID at https://flightaware.com/adsb/piaware/claim
PIAWARE_FEEDER_ID=00000000-0000-0000-0000-000000000000

# ---- Flightradar24 ----
# Get a sharing key by running `fr24feed --signup`
FR24_KEY=your-fr24-sharing-key-here

# ---- Which optional feeders to start ----
# Comma-separated. Available profiles: piaware, fr24
# Leave blank for ultrafeeder only.
COMPOSE_PROFILES=piaware
